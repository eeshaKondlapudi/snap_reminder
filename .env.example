# Local OCR parser server
# Used by: node server/llama_ocr_parse_server.mjs
OCR_PARSE_PORT=8788
HOST=127.0.0.1

# Optional Ollama cleanup for OCR results.
# Leave OLLAMA_CLEANUP_ENABLED=false unless Ollama is installed and running.
OLLAMA_CLEANUP_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_MS=60000

# Flutter uses a compile-time dart define for the parser endpoint, not this
# .env file. For an Android emulator, the default endpoint is:
# http://10.0.2.2:8788/parse-ocr
#
# To override it, run:
# flutter run --dart-define=OCR_PARSE_ENDPOINT=http://10.0.2.2:8788/parse-ocr

# Legacy Gemini scan server only.
# Used by: node server/gemini_ai_scan_server.mjs
# GEMINI_API_KEY=put_your_gemini_api_key_here
# PORT=8787
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TIMEOUT_MS=30000
